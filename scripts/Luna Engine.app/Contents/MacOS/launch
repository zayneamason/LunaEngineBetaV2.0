#!/bin/bash
# Luna Engine — Desktop Launcher
# Double-click to configure and launch Luna Engine.

# macOS .app bundles get a minimal PATH — load the user's shell environment
if [ -f "$HOME/.zshrc" ]; then
  source "$HOME/.zshrc" 2>/dev/null
elif [ -f "$HOME/.bash_profile" ]; then
  source "$HOME/.bash_profile" 2>/dev/null
fi

ROOT="/Users/zayneamason/_HeyLuna_BETA/_LunaEngine_BetaProject_V2.0_Root"

# Activate venv if it exists
if [ -f "$ROOT/.venv/bin/activate" ]; then
  source "$ROOT/.venv/bin/activate"
fi
CONFIG_FILE="$ROOT/config/luna.launch.json"
PID_FILE="/tmp/luna_launcher.pids"
LOG_FILE="/tmp/luna_engine.log"
LAUNCHER_HTML="$ROOT/scripts/luna_launcher.html"

# Check if already running — just open browser
if [ -f "$PID_FILE" ]; then
  FRONTEND_PORT=$(python3 -c "import json; print(json.load(open('$PID_FILE')).get('frontend',{}).get('port',5173))" 2>/dev/null || echo 5173)
  ALREADY_RUNNING=$(python3 -c "
import json, os
try:
    pids = json.load(open('$PID_FILE'))
    alive = any(True for info in pids.values() if info.get('pid') and not os.kill(info['pid'], 0))
except:
    alive = False
print('yes' if alive else 'no')
" 2>/dev/null)

  if [ "$ALREADY_RUNNING" = "yes" ]; then
    open "http://localhost:$FRONTEND_PORT"
    exit 0
  fi
fi

# Not running — ask what to do
CHOICE=$(osascript -e 'button returned of (display dialog "Luna Engine" buttons {"Configure", "Launch", "Cancel"} default button "Launch" with title "Luna Engine v2.0" with icon caution)')

if [ "$CHOICE" = "Cancel" ]; then
  exit 0
fi

if [ "$CHOICE" = "Configure" ]; then
  open "$LAUNCHER_HTML"
  exit 0
fi

# ── Launch ──

# Read config
BACKEND_PORT=8000
FRONTEND_PORT=5173
BACKEND_ENABLED=true
FRONTEND_ENABLED=true
OBSERVATORY_PORT=8100
OBSERVATORY_ENABLED=false

if [ -f "$CONFIG_FILE" ]; then
  eval "$(python3 -c "
import json
cfg = json.load(open('$CONFIG_FILE'))
s = cfg.get('services', {})
b = s.get('backend', {})
f = s.get('frontend', {})
o = s.get('observatory', {})
print(f'BACKEND_PORT={b.get(\"port\", 8000)}')
print(f'BACKEND_ENABLED={\"true\" if b.get(\"enabled\", True) else \"false\"}')
print(f'FRONTEND_PORT={f.get(\"port\", 5173)}')
print(f'FRONTEND_ENABLED={\"true\" if f.get(\"enabled\", True) else \"false\"}')
print(f'OBSERVATORY_PORT={o.get(\"port\", 8100)}')
print(f'OBSERVATORY_ENABLED={\"true\" if o.get(\"enabled\", False) else \"false\"}')
" 2>/dev/null)"
fi

# Clear log
> "$LOG_FILE"

# Start backend
if [ "$BACKEND_ENABLED" = "true" ]; then
  cd "$ROOT"
  python3 scripts/run.py --server --host 0.0.0.0 --port "$BACKEND_PORT" >> "$LOG_FILE" 2>&1 &
  BACKEND_PID=$!

  for i in $(seq 1 30); do
    if curl -s "http://localhost:$BACKEND_PORT/health" >/dev/null 2>&1; then
      break
    fi
    sleep 1
  done
fi

# Start frontend
if [ "$FRONTEND_ENABLED" = "true" ]; then
  cd "$ROOT/frontend"
  LUNA_BACKEND_PORT=$BACKEND_PORT LUNA_OBSERVATORY_PORT=$OBSERVATORY_PORT LUNA_FRONTEND_PORT=$FRONTEND_PORT \
  npm run dev >> "$LOG_FILE" 2>&1 &
  FRONTEND_PID=$!

  for i in $(seq 1 10); do
    if curl -s "http://localhost:$FRONTEND_PORT/" >/dev/null 2>&1; then
      break
    fi
    sleep 1
  done
fi

# Start observatory
if [ "$OBSERVATORY_ENABLED" = "true" ]; then
  cd "$ROOT/Tools/MemoryMatrix_SandBox"
  python3 mcp_server/server.py --http-only --port "$OBSERVATORY_PORT" >> "$LOG_FILE" 2>&1 &
  OBSERVATORY_PID=$!
fi

# Write PID file
python3 -c "
import json
pids = {}
$([ -n "$BACKEND_PID" ] && echo "pids['backend'] = {'pid': $BACKEND_PID, 'port': $BACKEND_PORT}")
$([ -n "$FRONTEND_PID" ] && echo "pids['frontend'] = {'pid': $FRONTEND_PID, 'port': $FRONTEND_PORT}")
$([ -n "$OBSERVATORY_PID" ] && echo "pids['observatory'] = {'pid': $OBSERVATORY_PID, 'port': $OBSERVATORY_PORT}")
with open('$PID_FILE', 'w') as f:
    json.dump(pids, f, indent=2)
"

# Open browser
if [ "$FRONTEND_ENABLED" = "true" ]; then
  open "http://localhost:$FRONTEND_PORT"
elif [ "$BACKEND_ENABLED" = "true" ]; then
  open "http://localhost:$BACKEND_PORT/health"
fi

# Notify
osascript -e "display notification \"Backend :$BACKEND_PORT  Frontend :$FRONTEND_PORT\" with title \"Luna Engine is live\""

# Keep alive
wait
