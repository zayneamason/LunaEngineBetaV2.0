    {
      "uuid": "02757294-56e0-41ba-894d-b965bd3f80fe",
      "text": "What model around this year would be better on gas?",
      "sender": "human",
      "index": 2,
      "created_at": "2024-10-21T23:37:18.378965Z",
      "updated_at": "2024-10-21T23:37:18.378965Z",
      "truncated": false,
