      "files": [],
      "files_v2": [],
      "sync_sources": [],
      "parent_message_uuid": "02757294-56e0-41ba-894d-b965bd3f80fe"
    },
    {
      "uuid": "986719c1-2856-408c-bad8-571377ab4521",
      "text": "What is mpg on 1",
      "sender": "human",
      "index": 4,
      "created_at": "2024-10-21T23:38:01.570603Z",
      "updated_at": "2024-10-21T23:38:01.570603Z",
