    {
      "uuid": "019bbff2-328f-750d-9ab7-b10588d82179",
      "text": "I want to make an emergency alert system for mars college community",
      "sender": "human",
      "index": 2,
      "created_at": "2026-01-15T04:37:59.664974Z",
      "updated_at": "2026-01-15T04:37:59.664974Z",
      "input_mode": "text",
      "truncated": false,
      "attachments": [],
