        {
          "section_number": "10",
          "section_title": "Ring Buffer Endpoints",
          "description": "These endpoints manage the conversation ring buffer",
          "endpoints": [
            {
              "method": "GET",
              "path": "/api/ring/status",
              "description": "Get current ring buffer status",
              "response": [
                {"field": "current_turns", "type": "int", "description": "Current turn count in buffer"},
                {"field": "max_turns", "type": "int", "description": "Maximum turns capacity"},
                {"field": "topics", "type": "list[string]", "description": "Detected conversation topics (max 10)"},
                {"field": "recent_messages", "type": "list[dict]", "description": "Recent messages (last 6)"}
              ],
              "curl_example": "curl http://localhost:8000/api/ring/status",
              "example_response": {
                "current_turns": 8,
                "max_turns": 10,
                "topics": ["python", "machine learning", "data processing"],
                "recent_messages": [
                  {"role": "user", "content": "How do I use pandas?"},
                  {"role": "assistant", "content": "Pandas is a powerful data..."}
                ]
              }
            },
            {
              "method": "POST",
              "path": "/api/ring/config",
              "description": "Configure the ring buffer size",
              "request_body": [
                {"field": "max_turns", "type": "int", "required": true, "constraints": "2-20", "description": "Maximum turns capacity"}
              ],
              "response": [
                {"field": "status", "type": "string", "description": "\"configured\""},
                {"field": "previous_max_turns", "type": "int", "description": "Previous capacity"},
                {"field": "new_max_turns", "type": "int", "description": "New capacity"},
                {"field": "current_turns", "type": "int", "description": "Current turn count"}
              ],
              "curl_example": "curl -X POST http://localhost:8000/api/ring/config \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"max_turns\": 15}'",
              "example_response": {
                "status": "configured",
                "previous_max_turns": 10,
                "new_max_turns": 15,
                "current_turns": 8
              }
            },
