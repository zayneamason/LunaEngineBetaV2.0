              "name": "Streaming Response",
              "code_block": {
                "language": "bash",
                "code": "# Stream response token by token\ncurl -X POST http://localhost:8000/stream \\\n  -H \"Content-Type: application/json\" \\\n  -H \"Accept: text/event-stream\" \\\n  -d '{\"message\": \"Write a haiku about programming\"}'"
              }
            },
            {
              "name": "Context-Aware Streaming",
              "code_block": {
                "language": "bash",
                "code": "# Get context first, then stream response\ncurl -X POST http://localhost:8000/persona/stream \\\n  -H \"Content-Type: application/json\" \\\n  -H \"Accept: text/event-stream\" \\\n  -d '{\"message\": \"What have we discussed?\"}'"
              }
            },
            {
              "name": "Monitor Thoughts",
              "code_block": {
                "language": "bash",
                "code": "# Open a persistent connection to monitor Luna's thinking\ncurl http://localhost:8000/thoughts \\\n  -H \"Accept: text/event-stream\""
              }
            },
