            {"layer": "Charts", "technology": "Recharts 3.6.0", "purpose": "Data visualization"},
            {"layer": "State", "technology": "Custom Hooks", "purpose": "API communication"},
            {"layer": "Real-time", "technology": "Server-Sent Events", "purpose": "Live updates"}
          ],
          "architecture_principles": [
            "No External State Library - Custom hooks manage all state (no Redux, no React Query)",
            "Hooks-Based API Layer - Five custom hooks (`useLunaAPI`, `useChat`, `useVoice`, `useOrbState`, `useOrbFollow`)",
            "Glass Morphism Design - Consistent dark mode aesthetic with blur effects",
            "SSE for Real-Time - Server-Sent Events for voice status and thought streams",
            "WebSocket for Orb - Real-time orb state updates via `/ws/orb`",
            "Polling for Status - 2-second intervals for engine health and consciousness"
          ]
        },
