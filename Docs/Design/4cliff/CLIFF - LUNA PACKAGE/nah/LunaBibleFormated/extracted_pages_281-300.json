        {
          "section_number": "12",
          "section_title": "SSE Event Reference",
          "description": "Complete reference for all Server-Sent Events across streaming endpoints",
          "endpoints": [
            {
              "endpoint": "POST /stream",
              "events": [
                {"event": "token", "fields": "text: string", "description": "Generated token chunk"},
                {"event": "done", "fields": "model: string, input_tokens: int, output_tokens: int, latency_ms: float, delegated: bool, local: bool, fallback: bool", "description": "Generation complete with metadata"},
                {"event": "error", "fields": "error: string", "description": "Error message"}
              ]
            },
            {
              "endpoint": "POST /persona/stream",
              "description": "Uses typed JSON data format (no named SSE events)",
              "events": [
                {"type": "context", "fields": "memory: array, state: object", "description": "Memory items and engine state (sent first)"},
                {"type": "token", "fields": "text: string", "description": "Generated token chunk"},
                {"type": "done", "fields": "response: string, metadata: object", "description": "Full response and metadata"},
                {"type": "error", "fields": "message: string", "description": "Error message"}
              ],
              "memory_item_fields": [
                "id: string - Memory node ID",
                "content: string - Content (truncated to 200 chars)",
                "type: string - Node type (FACT, DECISION, etc.)",
                "source: string - Source identifier"
              ],
              "state_fields": [
                "session_id: string - Current session",
                "is_processing: bool - Always true during streaming",
                "state: string - Engine state name",
                "model: string - Current model"
              ]
            },
            {
              "endpoint": "GET /thoughts",
              "events": [
                {"event": "status", "fields": "connected: bool, is_processing: bool, goal: string", "description": "Initial connection status"},
                {"event": "thought", "fields": "type: \"thought\", message: string, is_processing: bool, goal: string", "description": "Internal thought/progress"},
                {"event": "phase", "fields": "type: \"phase\", phase: string, is_processing: bool, goal: string", "description": "Processing phase change"},
                {"event": "step", "fields": "type: \"step\", step_num: int, total_steps: int, description: string, is_processing: bool, goal: string", "description": "Plan step execution"},
                {"event": "ping", "fields": "is_processing: bool, pending: int", "description": "Keepalive (every 15s)"}
              ],
              "thought_message_prefixes": [
                {"prefix": "[DIRECT]", "meaning": "Direct response (no planning)"},
                {"prefix": "[PLAN]", "meaning": "Creating a plan"},
                {"prefix": "[STEP]", "meaning": "Executing plan step"},
                {"prefix": "[TOOL]", "meaning": "Using a tool"},
                {"prefix": "[OK]", "meaning": "Success"},
                {"prefix": "[ERROR]", "meaning": "Error occurred"},
                {"prefix": "[ABORT]", "meaning": "Task aborted"}
              ],
              "processing_phases": [
                {"phase": "idle", "description": "No active processing"},
                {"phase": "planning", "description": "Creating a plan"},
                {"phase": "observing", "description": "Gathering context"},
                {"phase": "thinking", "description": "Processing/reasoning"},
                {"phase": "acting", "description": "Executing actions"}
              ]
            },
            {
              "endpoint": "GET /voice/stream",
              "events": [
                {"event": "status", "fields": "connected: bool, status: string, running: bool", "description": "Voice system status"},
                {"event": "transcription", "fields": "type: \"transcription\", text: string", "description": "User speech transcribed"},
                {"event": "response", "fields": "type: \"response\", text: string", "description": "Luna's response ready"},
                {"event": "ping", "fields": "running: bool", "description": "Keepalive (every 10s)"}
              ],
              "voice_status_values": [
                {"status": "inactive", "description": "Voice system not started"},
                {"status": "idle", "description": "Ready, not recording"},
                {"status": "listening", "description": "Recording user speech"},
                {"status": "thinking", "description": "Processing/generating"},
                {"status": "speaking", "description": "Playing TTS audio"}
              ]
            }
          ]
        },
