          "endpoints": [
            {
              "method": "GET",
              "path": "/tuning/params/{name}",
              "description": "Get a parameter value",
              "path_parameters": [
                {"parameter": "name", "type": "string", "description": "Parameter name (use `/` for path-style names)"}
              ],
              "response": [
                {"field": "name", "type": "string", "description": "Parameter name"},
                {"field": "value", "type": "float", "description": "Current value"},
                {"field": "default", "type": "float", "description": "Default value"},
                {"field": "bounds", "type": "tuple", "description": "(min, max) bounds"},
                {"field": "step", "type": "float", "description": "Step size for adjustments"},
                {"field": "category", "type": "string", "description": "Parameter category"},
                {"field": "description", "type": "string", "description": "Parameter description"},
                {"field": "is_overridden", "type": "bool", "description": "Whether value differs from default"}
              ],
              "curl_example": "curl http://localhost:8000/tuning/params/memory/lock_in_threshold"
