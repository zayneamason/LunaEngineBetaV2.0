        {
          "section_number": "14",
          "section_title": "Examples",
          "examples": [
            {
              "name": "Basic Conversation",
              "code_block": {
                "language": "bash",
                "code": "# Send a message and get response\ncurl -X POST http://localhost:8000/message \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"message\": \"What is the capital of France?\"}'"
              }
            },
