              "name": "Create Memory",
              "code_block": {
                "language": "bash",
                "code": "# Create a new memory node\ncurl -X POST http://localhost:8000/memory/nodes \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"node_type\": \"PREFERENCE\",\n    \"content\": \"User prefers concise explanations\",\n    \"importance\": 0.8\n  }'"
