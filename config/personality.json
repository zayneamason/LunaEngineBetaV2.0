{
  "personality_patch_storage": {
    "mode": "memory_nodes",
    "node_type": "PERSONALITY_REFLECTION",
    "settings": {
      "initial_lock_in": 0.7,
      "consolidation_threshold": 50,
      "max_active_patches": 100,
      "decay_days_threshold": 30,
