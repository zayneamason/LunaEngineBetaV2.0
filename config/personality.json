    },
    "min_confidence_for_patch": 0.7
  },
  "lifecycle": {
    "decay_enabled": true,
    "consolidation_enabled": true,
    "maintenance_interval_hours": 24
  },
  "bootstrap": {
    "enabled": true,
    "run_on_first_launch": true,
    "protect_core_patches": true,
    "seed_patches": [
      {
        "patch_id": "bootstrap_001_sovereignty",
